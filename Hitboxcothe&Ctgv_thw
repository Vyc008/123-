-- LOGIC XỬ LÝ KHỐI HITBOX (KHÔNG BỊ ĐẨY / XUYÊN HITBOX)
local function applyHitboxLogic(v, enable)
    pcall(function()
        local char = v.Character
        if not char then return end
        
        local targetParts = {
            { enabled = getgenv().HitboxHead, names = {"Head"}, defSize = Vector3.new(2, 1, 1) },
            { enabled = getgenv().HitboxTorso, names = {"Torso", "UpperTorso", "LowerTorso", "HumanoidRootPart"}, defSize = Vector3.new(2, 2, 1) },
            { enabled = getgenv().HitboxArms, names = {"Left Arm", "Right Arm", "LeftUpperArm", "LeftLowerArm", "LeftHand", "RightUpperArm", "RightLowerArm", "RightHand"}, defSize = Vector3.new(1, 2, 1) },
            { enabled = getgenv().HitboxLegs, names = {"Left Leg", "Right Leg", "LeftUpperLeg", "LeftLowerLeg", "LeftFoot", "RightUpperLeg", "RightLowerLeg", "RightFoot"}, defSize = Vector3.new(1, 2, 1) }
        }

        local sizeNum = tonumber(getgenv().HitboxSize) or 15
        local transNum = tonumber(getgenv().HitboxTransparency) or 0.9
        local targetSize = Vector3.new(sizeNum, sizeNum, sizeNum)

        for _, group in ipairs(targetParts) do
            for _, partName in ipairs(group.names) do
                local part = char:FindFirstChild(partName)
                if part and part:IsA("BasePart") then
                    if enable and group.enabled then
                        if part.Size ~= targetSize then
                            part.Size = targetSize
                            part.Transparency = transNum
                            part.BrickColor = BrickColor.new("Really black")
                            part.Material = Enum.Material.Neon
                            part.Massless = true
                        end
                        part.CanCollide = false
                    else
                        if part.Size ~= group.defSize then
                            part.Size = group.defSize
                            part.BrickColor = BrickColor.new("Medium stone grey")
                            part.Material = Enum.Material.Plastic
                            part.Massless = false
                            if partName == "HumanoidRootPart" then part.Transparency = 1 else part.Transparency = 0 end
                        end
                        if partName == "HumanoidRootPart" then part.CanCollide = false else part.CanCollide = true end
                    end
                end
            end
        end
    end)
end

-- VÒNG LẶP CHẠY NGẦM TẬP TRUNG TỐI ƯU
RunService.RenderStepped:Connect(function()
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= Player then
            if getgenv().HitboxStatus then
                if getgenv().TeamCheck then
                    if Player.Team ~= v.Team then applyHitboxLogic(v, true) else applyHitboxLogic(v, false) end
                else
                    applyHitboxLogic(v, true)
                end
            else
                applyHitboxLogic(v, false)
            end
        end
    end
end)

RunService.Heartbeat:Connect(function()
    local char = Player.Character
    local hum = char and char:FindFirstChildWhichIsA("Humanoid")
    if char and hum then
        if getgenv().loopW then hum.WalkSpeed = tonumber(getgenv().Walkspeed) or 16 end
        if getgenv().loopJ then hum.JumpPower = tonumber(getgenv().Jumppower) or 50 end
        if getgenv().Noclip then
            for _, part in ipairs(char:GetChildren()) do
                if part:IsA("BasePart") and (part.Name == "Head" or part.Name == "Torso" or part.Name == "UpperTorso" or part.Name == "LowerTorso") then
                    part.CanCollide = false
                end
            end
        end
    end
end)

UserInputService.JumpRequest:Connect(function()
    if getgenv().InfJ then
        local char = Player.Character
        local hum = char and char:FindFirstChildOfClass('Humanoid')
        if hum then hum:ChangeState("Jumping") end
    end
end)
