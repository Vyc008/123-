end)

local function createLimbTrail(part)
    local a0 = Instance.new("Attachment", part) a0.Position = Vector3.new(0, 0.15, 0) 
    local a1 = Instance.new("Attachment", part) a1.Position = Vector3.new(0, -0.15, 0) 
    local trail = Instance.new("Trail")
    trail.Attachment0 = a0 trail.Attachment1 = a1
    trail.Color = ColorSequence.new(effectColors.Trail) trail.FaceCamera = true trail.LightEmission = 1
    trail.Transparency = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(0.8, 0.2), NumberSequenceKeypoint.new(1, 1)})
    trail.Lifetime = 2.0 trail.Enabled = false trail.Parent = part
    return trail
end

local function createSparks(parent)
    local emitter = Instance.new("ParticleEmitter")
    emitter.Color = ColorSequence.new(effectColors.Sparks)
    emitter.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0.8), NumberSequenceKeypoint.new(1, 0)})
    emitter.Lifetime = NumberRange.new(0.5, 1.0) 
    emitter.Rate = 0
    emitter.Speed = NumberRange.new(5, 15) 
    emitter.SpreadAngle = Vector2.new(180, 180)
    emitter.EmissionDirection = Enum.NormalId.Back 
    emitter.ZOffset = 1
    emitter.Parent = parent
    return emitter
end

-- ==========================================
-- ĐÃ CẢI TIẾN: HỆ THỐNG TIA SÉT DÀY VÀ ĐẸP HƠN
-- ==========================================
local function createLightningEmitter(parent)
    local emitter = Instance.new("ParticleEmitter")
    emitter.Color = ColorSequence.new(effectColors.Lightning)
    -- Kích thước tia sét to và rõ hơn ở điểm giữa
    emitter.Size = NumberSequence.new({NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(0.15, 3.5), NumberSequenceKeypoint.new(1, 0)})
    -- Thời gian tồn tại cực ngắn giúp sét chớp giật liên tục, không bị kéo vệt giống khói
    emitter.Lifetime = NumberRange.new(0.15, 0.4) 
    emitter.Rate = 0
    -- Tốc độ phóng tia sét nhanh và bung rộng hơn
    emitter.Speed = NumberRange.new(15, 35) 
    emitter.SpreadAngle = Vector2.new(360, 360) 
    emitter.EmissionDirection = Enum.NormalId.Back 
    emitter.LightEmission = 1
    emitter.Orientation = Enum.ParticleOrientation.VelocityParallel
    -- Tăng độ dẹp dài (Squash) làm hạt kéo dãn ra nhìn như tia sét thực thụ
    emitter.Squash = NumberSequence.new(6) 
    emitter.Drag = 2 
    emitter.ZOffset = 1.5
    emitter.Parent = parent
    return emitter
end

local validLimbs = {
    ["Left Leg"] = true, ["Right Leg"] = true, ["Left Arm"] = true, ["Right Arm"] = true,
    ["LeftFoot"] = true, ["RightFoot"] = true, ["LeftHand"] = true, ["RightHand"] = true,
    ["UpperTorso"] = true, ["LowerTorso"] = true, ["Head"] = true
}

local function setupCharacter(char)
    local hrp = char:WaitForChild("HumanoidRootPart", 5)
    local humanoid = char:WaitForChild("Humanoid", 5)
    if not hrp or not humanoid then return end

    for _, t in ipairs(currentTrails) do t:Destroy() end
    currentTrails = {}
    if currentSparks then currentSparks:Destroy() end
    if currentLightning then currentLightning:Destroy() end
    if currentLight then currentLight:Destroy() end

    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") and validLimbs[part.Name] then
            table.insert(currentTrails, createLimbTrail(part))
        end
    end
    table.insert(currentTrails, createLimbTrail(hrp))

    currentSparks = createSparks(hrp)
    currentLightning = createLightningEmitter(hrp)

    currentLight = Instance.new("PointLight")
    currentLight.Color = effectColors.Light
    currentLight.Range = 15 currentLight.Brightness = 3 currentLight.Enabled = false currentLight.Parent = hrp
end

if LocalPlayer.Character then setupCharacter(LocalPlayer.Character) end
registerConn(LocalPlayer.CharacterAdded:Connect(setupCharacter))

-- ==========================================
-- HỆ THỐNG BÓNG HÌNH ĐỈNH CAO (RÕ HƠN, ẨN LÂU HƠN)
-- ==========================================
local function createAfterImage(char)
    for _, part in pairs(char:GetDescendants()) do
        if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" and part.Transparency < 1 then
            part.Archivable = true
            local success, clonePart = pcall(function() return part:Clone() end)
            if success and clonePart then
                clonePart.Anchored = true 
                clonePart.CanCollide = false 
                clonePart.CFrame = part.CFrame
                clonePart.Material = Enum.Material.Neon 
                clonePart.Color = effectColors.Afterimage 
                clonePart.Transparency = 0.1
                clonePart.Massless = true
                
                for _, child in pairs(clonePart:GetChildren()) do 
                    if not child:IsA("DataModelMesh") and not child:IsA("SpecialMesh") then 
                        child:Destroy() 
                    end 
                end
                
                clonePart.Parent = workspace
                
                local tweenInfo = TweenInfo.new(1.2, Enum.EasingStyle.Linear, Enum.EasingDirection.Out)
                local tween = TweenService:Create(clonePart, tweenInfo, {Transparency = 1})
                tween:Play()
                
                Debris:AddItem(clonePart, 1.2) 
            end
        end
    end
end

-- ==========================================
-- VÒNG LẶP TRẠNG THÁI (CORE ENGINE)
-- ==========================================
registerConn(RunService.Heartbeat:Connect(function(deltaTime)
    local char = LocalPlayer.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    
    if hrp and humanoid then
        local isMoving = humanoid.MoveDirection.Magnitude > 0
        local activeSpeeding = isSpeedToggled or UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
        local currState = humanoid:GetState()

        if activeSpeeding and isMoving then
            local moveVector = humanoid.MoveDirection * (FLASH_SPEED * deltaTime)
            hrp.CFrame = hrp.CFrame + moveVector
            
            if currentSparks then currentSparks.Rate = 75 end
            -- TĂNG MẠNH: Đẩy số lượng hạt tia sét từ 40 lên hẳn 180 hạt/giây cực kỳ dày đặc
            if currentLightning then currentLightning.Rate = 180 end 
            
            wasMovingFast = true

            if tick() - lastAfterImage > 0.02 then
                createAfterImage(char)
                lastAfterImage = tick()
            end
        else
            if currentSparks then currentSparks.Rate = 0 end
            if currentLightning then currentLightning.Rate = 0 end
            
            if wasMovingFast then
                wasMovingFast = false
                if currState ~= Enum.HumanoidStateType.Jumping and currState ~= Enum.HumanoidStateType.Freefall then
                    local lookDir = hrp.CFrame.LookVector
                    task.spawn(function()
                        for i = 1, 10 do
                            local dt = RunService.Heartbeat:Wait()
                            if hrp then
                                hrp.CFrame = hrp.CFrame + (lookDir * (FLASH_SPEED * 0.15 * (1 - i/10) * dt))
                            end
                        end
                    end)
                end
            end
        end
    end
end))

registerConn(UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.LeftShift then updateEffectsState(true) end
end))

registerConn(UserInputService.InputEnded:Connect(function(input, gpe)
    if input.KeyCode == Enum.KeyCode.LeftShift and not isSpeedToggled then updateEffectsState(false) end
end))
