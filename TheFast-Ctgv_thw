local function getDynamicFOV()
    return math.clamp(NORMAL_FOV + (FLASH_SPEED * 0.2), NORMAL_FOV, 120)
end

local function updateEffectsState(state)
    isSpeeding = state
    local cam = workspace.CurrentCamera
    if isSpeeding then
        for _, trail in ipairs(currentTrails) do trail.Enabled = true end
        if currentLight then currentLight.Enabled = true end
        if cam then TweenService:Create(cam, TweenInfo.new(0.4), {FieldOfView = getDynamicFOV()}):Play() end
    else
        for _, trail in ipairs(currentTrails) do trail.Enabled = false end
        if currentLight then currentLight.Enabled = false end
        if cam then TweenService:Create(cam, TweenInfo.new(0.3), {FieldOfView = NORMAL_FOV}):Play() end
    end
end

