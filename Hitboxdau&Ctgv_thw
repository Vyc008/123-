-- ==========================================
-- LÕI XỬ LÝ GAMEPLAY (HEAD)
-- ==========================================
local defaultSize = Vector3_new(2, 1, 1)

local function applyHitboxLogic(v, enable)
    local char = v.Character
    if not char then return end

    local head = char:FindFirstChild("Head")
    if not head then return end

    if enable then
        local sizeNum = tonumber(getgenv().HitboxSize) or 15
        local transNum = tonumber(getgenv().HitboxTransparency) or 0.5
        local targetSize = Vector3_new(sizeNum, sizeNum, sizeNum)

        local mesh = head:FindFirstChildWhichIsA("SpecialMesh") or head:FindFirstChild("Mesh")
        if mesh then mesh:Destroy() end

        if head.Size ~= targetSize then head.Size = targetSize end
        if head.Transparency ~= transNum then head.Transparency = transNum end
        if head.CanCollide then head.CanCollide = false end
        if not head.Massless then head.Massless = true end
        if head.Material ~= Enum.Material.Neon then 
            head.BrickColor = BrickColor.new("Really black")
            head.Material = Enum.Material.Neon 
        end
    else
        if head.Size ~= defaultSize then
            head.Size = defaultSize
            head.Transparency = 0
            head.BrickColor = BrickColor.new("Medium stone grey")
            head.Material = Enum.Material.Plastic
            head.CanCollide = true
            head.Massless = false 
        end
    end
end

RunService.Heartbeat:Connect(function()
    local isHitboxOn = getgenv().HitboxStatus
    local isTeamCheckOn = getgenv().TeamCheck
    local localTeam = Player.Team
    
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= Player then
            if isHitboxOn then
                if isTeamCheckOn and v.Team == localTeam then
                    applyHitboxLogic(v, false)
                else
                    applyHitboxLogic(v, true)
                end
            else
                applyHitboxLogic(v, false)
            end
        end
    end

    if localChar and localHum and localHum.Parent then
        if getgenv().loopW then 
            local targetWS = tonumber(getgenv().Walkspeed) or 16
            if localHum.WalkSpeed ~= targetWS then localHum.WalkSpeed = targetWS end 
        end
        if getgenv().loopJ then 
            local targetJP = tonumber(getgenv().Jumppower) or 50
            if localHum.JumpPower ~= targetJP then localHum.JumpPower = targetJP end 
        end

        if getgenv().TPWalk and localHum.MoveDirection.Magnitude > 0 then
            local speed = tonumber(getgenv().TPSpeed) or 3
            localChar:TranslateBy(localHum.MoveDirection * speed)
        end
    end
end)

