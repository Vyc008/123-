local function createTextBoxRow(labelText, defaultValue, targetScroll, callback)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, 0, 0, 26)
    Container.BackgroundTransparency = 1
    Container.Parent = targetScroll

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0, 130, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(210, 210, 215)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 11
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Container

    local Input = Instance.new("TextBox")
    Input.Size = UDim2.new(0, 70, 1, 0)
    Input.Position = UDim2.new(1, -75, 0, 0)
    Input.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    Input.Text = tostring(defaultValue)
    Input.TextColor3 = Color3.fromRGB(255, 255, 255)
    Input.Font = Enum.Font.Gotham
    Input.TextSize = 11
    Input.Parent = Container
    applyUICorner(Input, 5)
    applyUIStroke(Input, Color3.fromRGB(80, 80, 85), 1)

    Input.FocusLost:Connect(function() callback(Input.Text) end)
    return Input
end

local function createToggleRow(labelText, defaultState, targetScroll, callback)
    local Container = Instance.new("Frame")
    Container.Size = UDim2.new(1, 0, 0, 26)
    Container.BackgroundTransparency = 1
    Container.Parent = targetScroll

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0, 130, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(210, 210, 215)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 11
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Parent = Container

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0, 70, 1, 0)
    Btn.Position = UDim2.new(1, -75, 0, 0)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 10
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.Parent = Container
    applyUICorner(Btn, 5)

    local state = defaultState
    local function updateVisuals()
        Btn.Text = state and "ON" or "OFF"
        Btn.BackgroundColor3 = state and Color3.fromRGB(80, 150, 80) or Color3.fromRGB(60, 60, 65)
    end
    updateVisuals()

    Btn.Activated:Connect(function()
        state = not state
        updateVisuals()
        callback(state)
    end)
    return function(externalState)
        state = externalState
        updateVisuals()
    end
end

local function createButtonRow(btnText, targetScroll, callback)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, -10, 0, 28)
