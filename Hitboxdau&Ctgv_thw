-- HIỆU ỨNG TWEEN ẨN/HIỆN (BATMAN GUI STYLE)
-- ==========================================
local isMenuOpen = false

local function toggleMenu()
    isMenuOpen = not isMenuOpen
    if isMenuOpen then
        MainFrame.Visible = true
        -- Hiệu ứng phóng to với độ nảy nhẹ (Back Out)
        TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 480, 0, 350)
        }):Play()
    else
        -- Hiệu ứng thu nhỏ dần đến biến mất (Quad In)
        local closeTween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0)
        })
        closeTween:Play()
        closeTween.Completed:Connect(function()
            if not isMenuOpen then MainFrame.Visible = false end
        end)
    end
end

ToggleUIBtn.Activated:Connect(toggleMenu)
