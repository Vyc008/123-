-- Cache Local Player Data để tối ưu tốc độ xử lý
local localChar, localHum, localParts
local Vector3_new = Vector3.new

local function updateLocalStats(char)
    if not char then return end
    localChar = char
    localHum = char:WaitForChild("Humanoid", 3)
    
    localParts = {}
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            table.insert(localParts, part)
        end
    end
    
    if localHum then
        getgenv().Walkspeed = localHum.WalkSpeed
        getgenv().Jumppower = localHum.JumpPower
    end
end

