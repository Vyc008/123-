-- ==========================================
local ESP = {}
local activeHighlights = 0

local function shouldESP(p)
    if p == Player then return false end
    if not ESPSettings.ESPTeammates then
        if Player.Team and p.Team and Player.Team == p.Team then return false end
    end
    return true
end

local function getESPColor(p)
    if CustomPlayerColors[p.Name] then return CustomPlayerColors[p.Name] end
    if currentESPColor then return currentESPColor end 
    if p.Team then return p.Team.TeamColor.Color end 
    return NO_TEAM_COLOR 
end

local function cleanESP(p)
    if ESP[p] then
        pcall(function() if ESP[p].Box then ESP[p].Box:Destroy() end end)
        pcall(function() if ESP[p].HL then ESP[p].HL:Destroy(); activeHighlights = activeHighlights - 1 end end)
        pcall(function() if ESP[p].BB then ESP[p].BB:Destroy() end end)
        pcall(function() 
            if ESP[p].Tracer then 
                ESP[p].Tracer:Remove() 
                local idx = table.find(getgenv()._ESP_Tracer_Cache, ESP[p].Tracer)
                if idx then table.remove(getgenv()._ESP_Tracer_Cache, idx) end
            end 
        end)
        ESP[p] = nil
    end
end

local function setupESP(p)
    if p == Player then return end
    cleanESP(p)

    local box = Instance.new("SelectionBox")
    box.LineThickness = 0.05
    box.SurfaceTransparency = 1
    box.Parent = ScreenGui 

    local hl = Instance.new("Highlight")
    hl.FillTransparency = 1
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Enabled = false 
    if activeHighlights < 31 then
        hl.Parent = ScreenGui 
        activeHighlights = activeHighlights + 1
    end

    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(0, 200, 0, 40)
    bb.AlwaysOnTop = true
    bb.StudsOffset = Vector3.new(0, 3, 0)
    bb.Parent = ScreenGui 

    local txt = Instance.new("TextLabel", bb)
    txt.Size = UDim2.new(1, 0, 1, 0)
    txt.BackgroundTransparency = 1
    txt.Font = Enum.Font.SourceSansBold
    txt.TextStrokeTransparency = 0.5 
    txt.TextSize = 13

    local tracer = Drawing.new("Line")
    tracer.Visible = false
    tracer.Color = Color3.new(1, 1, 1)
    tracer.Thickness = 1.5
    tracer.Transparency = 1
    table.insert(getgenv()._ESP_Tracer_Cache, tracer)

    ESP[p] = {Box = box, HL = hl, BB = bb, TXT = txt, Tracer = tracer}
end

for _, p in pairs(Players:GetPlayers()) do setupESP(p) end
Players.PlayerAdded:Connect(function(p) setupESP(p); RefreshPlayerList() end)
Players.PlayerRemoving:Connect(function(p)
    cleanESP(p) 
    if CustomPlayerColors[p.Name] then CustomPlayerColors[p.Name] = nil end
    if SelectedPlayerName == p.Name then SetSelectedPlayer(nil) end
    RefreshPlayerList() 
end)

local function RebuildHighlights()
    activeHighlights = 0
    for p, e in pairs(ESP) do
        if e.HL then
            e.HL:Destroy()
            if activeHighlights < 31 then
                local newHl = Instance.new("Highlight")
                newHl.FillTransparency = 1
                newHl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                newHl.Parent = ScreenGui 
                e.HL = newHl
                activeHighlights = activeHighlights + 1
            else e.HL = nil end
        end
    end
end

UserInputService.WindowFocused:Connect(RebuildHighlights)
FixBtn.MouseButton1Click:Connect(RebuildHighlights)

getgenv()._ESP_RenderLoop = RunService.RenderStepped:Connect(function()
    local CamPos = Cam.CFrame.Position 
    local ViewportCenter = Vector2.new(Cam.ViewportSize.X / 2, 0)

    for p, e in pairs(ESP) do
        if not p or p.Parent ~= Players then
            cleanESP(p)
            continue
        end

        local c = p.Character
        local hrp = c and c:FindFirstChild("HumanoidRootPart")
        local hum = c and c:FindFirstChildOfClass("Humanoid")
        
        local isVisible = hum and hum.Health > 0 and hrp and shouldESP(p)
        
        if isVisible then
            local col = getESPColor(p)
            e.Box.Color3 = col
            e.TXT.TextColor3 = col
            
            e.Box.Visible = ESPSettings.BoxESP
            e.Box.Adornee = ESPSettings.BoxESP and c or nil 
            
            if ESPSettings.OutlineESP and e.HL then
                e.HL.Enabled = true
                e.HL.OutlineColor = col
                e.HL.Adornee = c 
            elseif e.HL then
                e.HL.Enabled = false
                e.HL.Adornee = nil
            end

            local showBB = ESPSettings.ShowName or ESPSettings.ShowDistance
            e.BB.Enabled = showBB
            e.BB.Adornee = showBB and hrp or nil 

            if showBB then
                local t = ""
                if ESPSettings.ShowName then t = p.Name end
                if ESPSettings.ShowDistance then
                    local dist = math.floor((CamPos - hrp.Position).Magnitude)
                    t = ESPSettings.ShowName and (t .. " [" .. dist .. "m]") or (dist .. "m")
                end
                e.TXT.Text = t
            end

            if ESPSettings.TracerESP then
                local pos, onScreen = Cam:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    e.Tracer.From = ViewportCenter
                    e.Tracer.To = Vector2.new(pos.X, pos.Y)
                    e.Tracer.Color = col
                    e.Tracer.Visible = true
                else e.Tracer.Visible = false end
            else e.Tracer.Visible = false end
        else
            e.Box.Visible = false; e.Box.Adornee = nil
            if e.HL then e.HL.Enabled = false; e.HL.Adornee = nil end
            e.BB.Enabled = false; e.BB.Adornee = nil
            e.Tracer.Visible = false
        end
    end
end)

