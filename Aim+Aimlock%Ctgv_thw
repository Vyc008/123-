local function createAimbotSettingRow(parent, labelText, xPos, yPos, defaultValue)
    local Label = Instance.new("TextLabel", parent)
    Label.Size = UDim2.new(0, 110, 0, 30)
    Label.Position = UDim2.new(0, xPos, 0, yPos)
    Label.BackgroundTransparency = 1
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(220, 220, 220)
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local Input = Instance.new("TextBox", parent)
    Input.Size = UDim2.new(0, 80, 0, 30)
    Input.Position = UDim2.new(0, xPos + 115, 0, yPos)
    Input.BackgroundColor3 = Color3.fromRGB(50, 50, 55)
    Input.Text = tostring(defaultValue)
    Input.TextColor3 = Color3.fromRGB(255, 255, 255)
    Input.Font = Enum.Font.Gotham
    Input.TextSize = 12
    applyUICorner(Input, 6)
    applyUIStroke(Input, Color3.fromRGB(80, 80, 85), 1)
    return Input
end

local function createAimbotToggle(parent, textOn, textOff, xPos, yPos, configKey)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(0, 205, 0, 30)
    btn.Position = UDim2.new(0, xPos, 0, yPos)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    applyUICorner(btn, 6)
    
    local function update()
        local state = AimbotSettings[configKey]
        btn.Text = state and textOn or textOff
        btn.BackgroundColor3 = state and Color3.fromRGB(80, 150, 80) or Color3.fromRGB(60, 60, 65)
    end
    btn.Activated:Connect(function()
        AimbotSettings[configKey] = not AimbotSettings[configKey]
        update()
        if configKey == "ShowFov" then FOVring.Visible = isAiming and AimbotSettings.ShowFov end
        if configKey == "ShowFloatingBtn" then AimbotBtn.Visible = AimbotSettings.ShowFloatingBtn end
    end)
    update()
    return btn
end

