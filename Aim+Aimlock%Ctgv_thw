    AimbotBtn.Text = isAiming and "AIM\nON" or "AIM\nOFF"
    AimbotBtn.BackgroundColor3 = isAiming and Color3.fromRGB(80, 200, 80) or Color3.fromRGB(220, 60, 60)
    
