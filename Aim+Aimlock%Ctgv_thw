local function createESPToggle(text, x, y, width, key)
    local b = Instance.new("TextButton", ESPContainer)
    b.Size = UDim2.new(0, width, 0, 28)
    b.Position = UDim2.new(0, x, 0, y)
    b.Font = Enum.Font.GothamMedium
    b.TextSize = 12
    b.TextColor3 = Color3.new(1, 1, 1)
    applyUICorner(b, 5)

    local function refresh()
        b.Text = text .. ": " .. (ESPSettings[key] and "ON" or "OFF")
        b.BackgroundColor3 = ESPSettings[key] and Color3.fromRGB(0, 150, 0) or Color3.fromRGB(60, 60, 65)
    end
    refresh()

    b.MouseButton1Click:Connect(function()
        ESPSettings[key] = not ESPSettings[key]
        refresh()
    end)
end

