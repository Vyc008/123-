local function createToggleButton(parent, textOn, textOff, xPos, yPos, configKey)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 190, 0, 30)
    btn.Position = UDim2.new(0, xPos, 0, yPos)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Parent = parent
    applyUICorner(btn, 6)
    
    local function updateButtonUI()
        local state = Settings[configKey]
        btn.Text = state and textOn or textOff
        btn.BackgroundColor3 = state and Color3.fromRGB(80, 150, 80) or Color3.fromRGB(60, 60, 65)
    end
    
    btn.Activated:Connect(function()
        Settings[configKey] = not Settings[configKey]
        updateButtonUI()
        if configKey == "ShowFov" then 
            FOVring.Visible = isAiming and Settings.ShowFov 
        end
    end)
    updateButtonUI()
    return btn
end

