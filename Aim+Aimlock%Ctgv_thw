    FOVring.Visible = isAiming and Settings.ShowFov
    
    if not isAiming then 
        lockedTarget = nil 
        FocusCircle.Visible = false
    end
end
AimbotBtn.Activated:Connect(toggleAimbot)

local function getTargetPart(character)
    if not character then return nil end
    return character:FindFirstChild(Settings.FocusPart) or character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
end

local function checkWall(targetPlayer, targetPart)
    if not Settings.WallCheck then return true end
    if not targetPart then return false end
    local castParams = RaycastParams.new()
    castParams.FilterType = Enum.RaycastFilterType.Exclude
    
    local ignoreList = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then table.insert(ignoreList, p.Character) end
    end
    castParams.FilterDescendantsInstances = ignoreList
    castParams.IgnoreWater = true
    
    local origin = Cam.CFrame.Position
    local direction = targetPart.Position - origin
    local ray = workspace:Raycast(origin, direction, castParams)
    
    return ray == nil
end

local function isTargetValid(targetPlayer)
    if not targetPlayer or not targetPlayer.Parent then return false end
    local char = targetPlayer.Character
    if not char then return false end
    
    local targetPart = getTargetPart(char)
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    
    if not targetPart or not humanoid then return false end
    if Settings.DeadCheck and humanoid.Health <= 0 then return false end
    if Settings.TeamCheck and targetPlayer.Team == Player.Team then return false end
    if not checkWall(targetPlayer, targetPart) then return false end
    
    return true
end

-- Hàm tìm địch trong FOV ban đầu
local function getBestTarget()
    local bestTarget = nil
    local minFovDistance = math.huge
    local viewportCenter = Cam.ViewportSize / 2
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Player and isTargetValid(p) then
            local targetPart = getTargetPart(p.Character)
            if targetPart then
                local screenPos, visible = Cam:WorldToViewportPoint(targetPart.Position)
                if visible and screenPos.Z > 0 then
                    local fovDistance = (Vector2.new(screenPos.X, screenPos.Y) - viewportCenter).Magnitude
                    if fovDistance <= Settings.FovRadius and fovDistance < minFovDistance then
                        minFovDistance = fovDistance
                        bestTarget = p
                    end
                end
            end
        end
    end
    return bestTarget
end

local function aim(targetPosition)
    local screenPos, visible = Cam:WorldToViewportPoint(targetPosition)
    local currentCF = Cam.CFrame
    local targetDirection = (targetPosition - currentCF.Position).Unit

    if not visible then
        Cam.CFrame = CFrame.new(currentCF.Position, currentCF.Position + targetDirection)
        return
    end

    if Settings.AimMode == "Mouse" and mousemoverel then
        local center = Cam.ViewportSize / 2
        local deltaX = (screenPos.X - center.X) * Settings.Smooth
        local deltaY = (screenPos.Y - center.Y) * Settings.Smooth
        mousemoverel(math.round(deltaX), math.round(deltaY))
    else
        if Settings.Smooth == 1 then
            Cam.CFrame = CFrame.new(currentCF.Position, currentCF.Position + targetDirection)
        else
            local newLookVector = currentCF.LookVector:Lerp(targetDirection, Settings.Smooth)
            Cam.CFrame = CFrame.new(currentCF.Position, currentCF.Position + newLookVector)
        end
    end
end

-- ==========================================
-- THUẬT TOÁN ĐÃ TÙY CHỈNH THEO YÊU CẦU
-- ==========================================
RunService.RenderStepped:Connect(function()
    FOVring.Position = Cam.ViewportSize / 2
    FOVring.Radius = Settings.FovRadius

    if isAiming then
        local holdCurrentTarget = false
        
        if lockedTarget and isTargetValid(lockedTarget) then
            if Settings.LockTarget then
                -- YÊU CẦU: Khóa cứng, chạy ra khỏi vòng tròn FOV vẫn KHÔNG BUÔNG
                holdCurrentTarget = true
            else
                -- Chế độ thường: Địch ra ngoài FOV sẽ buông
                local tPart = getTargetPart(lockedTarget.Character)
                if tPart then
                    local sPos, vis = Cam:WorldToViewportPoint(tPart.Position)
                    if vis and (Vector2.new(sPos.X, sPos.Y) - Cam.ViewportSize / 2).Magnitude <= Settings.FovRadius then
                        holdCurrentTarget = true
                    end
                end
            end
        end

        if Settings.LockTarget then
            if not holdCurrentTarget then 
                lockedTarget = getBestTarget() 
            end
        else
            local potentialTarget = getBestTarget()
            if holdCurrentTarget and potentialTarget and potentialTarget ~= lockedTarget then
                local oldPart = getTargetPart(lockedTarget.Character)
                local newPart = getTargetPart(potentialTarget.Character)
                if oldPart and newPart then
                    local sOld, _ = Cam:WorldToViewportPoint(oldPart.Position)
                    local sNew, _ = Cam:WorldToViewportPoint(newPart.Position)
                    local dOld = (Vector2.new(sOld.X, sOld.Y) - Cam.ViewportSize / 2).Magnitude
                    local dNew = (Vector2.new(sNew.X, sNew.Y) - Cam.ViewportSize / 2).Magnitude
                    
                    if dNew < (dOld - 25) then
                        lockedTarget = potentialTarget
                    end
                end
            elseif not holdCurrentTarget then
                lockedTarget = potentialTarget
            end
        end

        -- DI CHUYỂN CAMERA VÀ XỬ LÝ ĐOÁN HƯỚNG (PREDICTION ON/OFF)
        if lockedTarget and lockedTarget.Character then
            local targetPart = getTargetPart(lockedTarget.Character)
            if targetPart then
                -- YÊU CẦU: Xử lý nút bật/tắt Đoán hướng
                local velocity = targetPart.AssemblyLinearVelocity
                if velocity.Magnitude > 100 then velocity = velocity.Unit * 100 end
                
                local currentPrediction = Settings.EnablePrediction and Settings.Prediction or 0
                local finalPos = targetPart.Position + (velocity * currentPrediction)
                
                aim(finalPos)
                
                if Settings.ShowFocus then
                    local screenPos, visible = Cam:WorldToViewportPoint(finalPos)
                    if visible then
                        FocusCircle.Position = Vector2.new(screenPos.X, screenPos.Y)
                        FocusCircle.Visible = true
                    else FocusCircle.Visible = false end
                else FocusCircle.Visible = false end
            else FocusCircle.Visible = false end
        else FocusCircle.Visible = false end
    else
        lockedTarget = nil
        FocusCircle.Visible = false
    end
end)

