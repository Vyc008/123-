-- ==========================================
-- LOGIC HITBOX ĐÃ TỐI ƯU HÓA (CHỈ XỬ LÝ THÂN TỰ ĐỘNG)
-- ==========================================
local function applyHitboxLogic(v, enable)
    local char = v.Character
    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if enable then
        local sizeNum = tonumber(getgenv().HitboxSize) or 15
        local transNum = tonumber(getgenv().HitboxTransparency) or 0.9
        local targetSize = Vector3.new(sizeNum, sizeNum, sizeNum)

        -- Chỉ cập nhật thuộc tính nếu giá trị thực tế bị sai (Tối ưu hóa tránh lag vật lý)
        if hrp.Size ~= targetSize then
            hrp.Size = targetSize
            hrp.Transparency = transNum
            hrp.BrickColor = BrickColor.new("Really black")
            hrp.Material = Enum.Material.Neon
            hrp.CanCollide = false
        end
    else
        local defaultSize = Vector3.new(2, 2, 1)
        if hrp.Size ~= defaultSize then
            hrp.Size = defaultSize
            hrp.Transparency = 1
            hrp.BrickColor = BrickColor.new("Medium stone grey")
            hrp.Material = Enum.Material.Plastic
            hrp.CanCollide = false
        end
    end
end

-- VÒNG LẶP RENDER CHẠY CỰC MƯỢT
RunService.RenderStepped:Connect(function()
    local isHitboxOn = getgenv().HitboxStatus
    local isTeamCheckOn = getgenv().TeamCheck
    local localTeam = Player.Team
    
    for _, v in ipairs(Players:GetPlayers()) do
        if v ~= Player then
            if isHitboxOn then
                if isTeamCheckOn and v.Team == localTeam then
                    applyHitboxLogic(v, false)
                else
                    applyHitboxLogic(v, true)
                end
            else
                applyHitboxLogic(v, false)
            end
        end
    end
end)

-- Vòng lặp cho các tính năng phụ của người chơi (Tối ưu hóa loop)
RunService.Heartbeat:Connect(function()
    local char = Player.Character
    local hum = char and char:FindFirstChildWhichIsA("Humanoid")
    if not (char and hum) then return end
    
    if getgenv().loopW then 
        local targetWS = tonumber(getgenv().Walkspeed) or 16
        if hum.WalkSpeed ~= targetWS then hum.WalkSpeed = targetWS end 
    end
    
    if getgenv().loopJ then 
        local targetJP = tonumber(getgenv().Jumppower) or 50
        if hum.JumpPower ~= targetJP then hum.JumpPower = targetJP end 
    end
    
    if getgenv().Noclip then
        for _, part in ipairs(char:GetChildren()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end)

UserInputService.JumpRequest:Connect(function()
    if getgenv().InfJ then
        local char = Player.Character
        local hum = char and char:FindFirstChildOfClass('Humanoid')
        if hum then hum:ChangeState("Jumping") end
    end
end)
