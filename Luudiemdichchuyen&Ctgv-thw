local isMenuOpen = false
local function toggleMenu()
    isMenuOpen = not isMenuOpen
    if isMenuOpen then
        MainFrame.Visible = true
        -- Tăng chiều cao UI lên 390 để chứa vừa thanh tìm kiếm
        TweenService:Create(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 300, 0, 390)
        }):Play()
    else
        local closeTween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0)
        })
        closeTween:Play()
        closeTween.Completed:Connect(function()
            if not isMenuOpen then MainFrame.Visible = false end
        end)
    end
end
ToggleUIBtn.Activated:Connect(toggleMenu)

-- Logic Lọc (Tìm kiếm)
SearchInput:GetPropertyChangedSignal("Text"):Connect(function()
    local searchText = string.lower(SearchInput.Text)
    for _, child in ipairs(ListScroll:GetChildren()) do
        if child:IsA("Frame") then
            local nameBox = child:FindFirstChildOfClass("TextBox")
            if nameBox then
                local locName = string.lower(nameBox.Text)
                if string.find(locName, searchText, 1, true) then
                    child.Visible = true
                else
                    child.Visible = false
                end
            end
        end
    end
end)

