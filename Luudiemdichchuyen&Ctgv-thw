    DelBtn.Size = UDim2.new(0.12, 0, 0, 25)
    DelBtn.Position = UDim2.new(0.68, 0, 0.5, -12.5) -- Vị trí 68%
    DelBtn.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
    DelBtn.Text = "🗑️"
    DelBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    DelBtn.Font = Enum.Font.GothamBold
    DelBtn.TextSize = 10
    DelBtn.Parent = Row
    applyUICorner(DelBtn, 5)

    -- 3. Nút Sửa Tên (Đứng đầu hàng nút, bên trái nút Xóa)
    local EditBtn = Instance.new("TextButton")
    EditBtn.Size = UDim2.new(0.12, 0, 0, 25)
    EditBtn.Position = UDim2.new(0.54, 0, 0.5, -12.5) -- Vị trí 54%
    EditBtn.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
    EditBtn.Text = "✏️"
    EditBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    EditBtn.Font = Enum.Font.GothamBold
    EditBtn.TextSize = 10
    EditBtn.Parent = Row
    applyUICorner(EditBtn, 5)

    -- [Sự kiện] Dịch chuyển
    TPBtn.Activated:Connect(function()
        local char = Player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = savedLocations[oldName]
            
            local oldColor = TPBtn.BackgroundColor3
            TPBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
            task.wait(0.2)
            TPBtn.BackgroundColor3 = oldColor
        end
    end)

    -- [Sự kiện] Xóa
    DelBtn.Activated:Connect(function()
        savedLocations[oldName] = nil
        Row:Destroy()
    end)

    -- [Sự kiện] Kích hoạt chế độ sửa tên
    EditBtn.Activated:Connect(function()
        RowNameInput.TextEditable = true
        RowNameInput:CaptureFocus()
        EditBtn.BackgroundColor3 = Color3.fromRGB(200, 150, 50)
    end)

    -- [Sự kiện] Lưu tên khi hoàn tất sửa
    RowNameInput.FocusLost:Connect(function()
        RowNameInput.TextEditable = false
        EditBtn.BackgroundColor3 = Color3.fromRGB(150, 150, 150)
        
        local newName = RowNameInput.Text
        
        if newName == oldName or newName:match("^%s*$") then
            RowNameInput.Text = oldName
            return
        end
        
        if savedLocations[newName] then
            RowNameInput.Text = oldName
            local oc = EditBtn.BackgroundColor3
            EditBtn.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
            task.wait(0.5)
            EditBtn.BackgroundColor3 = oc
            return
        end
        
        savedLocations[newName] = savedLocations[oldName]
        savedLocations[oldName] = nil
        oldName = newName
    end)
end

SaveBtn.Activated:Connect(function()
    local char = Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local currentCFrame = char.HumanoidRootPart.CFrame
        local inputName = NameInput.Text
        
        if inputName == "" or inputName:match("^%s*$") then
            locationCount = locationCount + 1
            inputName = "Vị trí " .. locationCount
        end

        if savedLocations[inputName] then
            NameInput.Text = "Tên đã tồn tại!"
            task.wait(1)
            NameInput.Text = ""
            return
        end

        savedLocations[inputName] = currentCFrame
        createLocationRow(inputName, currentCFrame)
        
        NameInput.Text = ""
        SaveBtn.Text = "✅ Đã lưu"
        task.wait(0.5)
        SaveBtn.Text = "💾 Lưu"
    end
end)
