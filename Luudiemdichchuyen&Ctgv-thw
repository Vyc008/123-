    RowNameInput.TextSize = 11
    RowNameInput.TextXAlignment = Enum.TextXAlignment.Left
    RowNameInput.TextEditable = false
    RowNameInput.ClearTextOnFocus = false
    RowNameInput.Parent = Row

    -- [SẮP XẾP TỪ PHẢI SANG TRÁI]
    
