local function SanitizeFileName(name)
    return string.gsub(name, '[\\/:*?"<>|]', "_")
end

local function InitFolder()
    if makefolder and not isfolder(FOLDER_NAME) then
        makefolder(FOLDER_NAME)
    end
end

local function SerializeCFrame(cf)
    return {cf:GetComponents()}
end

local function DeserializeCFrame(tab)
    return CFrame.new(unpack(tab))
end

local function SavePointToFile(name, cf)
    InitFolder()
    if writefile then
        local safeName = SanitizeFileName(name)
        local path = FOLDER_NAME .. "/" .. safeName .. ".json"
        local data = HttpService:JSONEncode({
            Name = name, 
            CFrameData = SerializeCFrame(cf)
        })
        pcall(function() writefile(path, data) end)
    end
end

local function DeletePointFile(name)
    if delfile then
        local safeName = SanitizeFileName(name)
        local path = FOLDER_NAME .. "/" .. safeName .. ".json"
        if isfile and isfile(path) then
            pcall(function() delfile(path) end)
        end
    end
end

