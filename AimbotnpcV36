local function updateColor()
    local r = tonumber(R_Input.Text) or 128
    local g = tonumber(G_Input.Text) or 0
    local b = tonumber(B_Input.Text) or 128
    
    r = math.clamp(r, 0, 255); R_Input.Text = tostring(r)
    g = math.clamp(g, 0, 255); G_Input.Text = tostring(g)
    b = math.clamp(b, 0, 255); B_Input.Text = tostring(b)

    FOVring.Color = Color3.fromRGB(r, g, b)
end

